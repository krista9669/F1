import matplotlib.pyplot as plt
import numpy as np
import fastf1
import os

# cache is created so that execution is sped up and repeated downloads can be avoided
if not os.path.exists('cache'):
    os.makedirs('cache')
fastf1.Cache.enable_cache('cache')

# we download, organize and process the raw lap data into structured format for analysis 
session = fastf1.get_session(2021, 'French Grand Prix', 'R')
session.load()

# here we get the fastest lap amongst all laps since it best represents the track
lap = session.laps.pick_fastest()
# the position of all the cars as they move is loaded which in turn gives the shape of the track
pos = lap.get_pos_data()

# extracting X and Y as the coordinates and converting them into a numpy array
track = pos.loc[:, ('X','Y')].to_numpy()

# get circuit rotation which is the angle of the track (in degrees) and later converted to radians
circuit_info = session.get_circuit_info()
track_angle = circuit_info.rotation / 180 * np.pi

# rotation function called the rotation transformation
def rotate(xy, *, angle):
    rot_mat = np.array([
        [np.cos(angle), -np.sin(angle)],
        [np.sin(angle),  np.cos(angle)]
    ])
    return np.matmul(xy, rot_mat)

# this rotates the entire circuit without this the track might look tilted
rotated_track = rotate(track, angle=track_angle)

fig, ax = plt.subplots(figsize=(5,5))

# draws track
ax.plot(rotated_track[:,0], rotated_track[:,1], color='black')

offset_vector = [500, 0]

for _, corner in circuit_info.corners.iterrows():
    txt = f"{corner['Number']}{corner['Letter']}"
    offset_angle = corner['Angle'] / 180 * np.pi
    
    offset_x, offset_y = rotate(offset_vector, angle=offset_angle)
    
    text_x = corner['X'] + offset_x
    text_y = corner['Y'] + offset_y

    text_x, text_y = rotate([text_x, text_y], angle=track_angle)
    track_x, track_y = rotate([corner['X'], corner['Y']], angle=track_angle)

    ax.scatter(text_x, text_y, color='black', s=150)
    ax.plot([track_x, text_x], [track_y, text_y], color='black')
    ax.text(text_x, text_y, txt, ha='center', va='center', color='white', size=8)

ax.set_title(session.event['Location'])
ax.set_xticks([])
ax.set_yticks([])
ax.axis('equal')

plt.show()
